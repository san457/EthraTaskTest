{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "typeRoots": ["./node_modules/@types", "./src-server/types"]
  },
  "include": ["src-server"],
  "exclude": ["node_modules", "dist-server"]
}
